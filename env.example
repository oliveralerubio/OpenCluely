# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Speech Recognition Configuration
# Choose one provider: azure, whisper, groq, openai-stt
SPEECH_PROVIDER=groq

# Optional: Azure Speech Services Configuration
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here

# Groq STT (fast cloud Whisper — recommended)
# Get key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
STT_MODEL=whisper-large-v3-turbo

# OpenAI-compatible STT (any provider with /audio/transcriptions endpoint)
# STT_API_KEY=your_key_here
# STT_API_BASE_URL=https://api.openai.com/v1
# STT_MODEL=whisper-1

# Optional: Local OpenAI Whisper Configuration
# Requires a local Whisper CLI installation, for example:
#   pip install openai-whisper
#   brew install ffmpeg sox
# Use `whisper`, `python3 -m whisper`, or on Windows `.venv-whisper/Scripts/whisper.exe`
WHISPER_COMMAND=whisper
WHISPER_MODEL_DIR=.whisper-models
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_SEGMENT_MS=4000
